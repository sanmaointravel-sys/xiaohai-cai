/* pages/children/children.wxss */
page { background: #F5F5F5; font-family: -apple-system, sans-serif; }
.container { padding: 20rpx; }

.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: #333; }
.add-btn {
  background: #FF9800; color: #fff; border: none; border-radius: 50rpx;
  padding: 16rpx 32rpx; font-size: 28rpx;
}
.add-btn::after { border: none; }

.child-list { display: flex; flex-direction: column; gap: 20rpx; }

.child-card {
  background: #fff; border-radius: 16rpx; padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.child-top { display: flex; align-items: center; margin-bottom: 16rpx; }
.avatar {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: #FF9800; color: #fff; font-size: 32rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
}
.info { flex: 1; margin-left: 20rpx; }
.name { font-size: 32rpx; font-weight: 600; color: #333; display: block; }
.meta { font-size: 24rpx; color: #999; }
.arrow { font-size: 40rpx; color: #ccc; }

.tag-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.tag { background: #FFF3E0; color: #E65100; border-radius: 20rpx; padding: 6rpx 16rpx; font-size: 24rpx; }
.tag-more { color: #999; font-size: 24rpx; }

.illness-row { background: #FFF3E0; border-radius: 12rpx; padding: 12rpx 16rpx; display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.illness-text { font-size: 26rpx; color: #E65100; flex: 1; }
.clear-btn { font-size: 24rpx; color: #FF9800; }

.quick-illness { margin-bottom: 12rpx; }
.quick-label { font-size: 24rpx; color: #999; display: block; margin-bottom: 8rpx; }
.quick-btns { display: flex; flex-wrap: wrap; gap: 8rpx; }
.quick-btn {
  background: #F5F5F5; color: #666; border: none; border-radius: 20rpx;
  padding: 8rpx 20rpx; font-size: 24rpx;
}
.quick-btn::after { border: none; }

.card-footer { display: flex; justify-content: flex-end; border-top: 1rpx solid #eee; padding-top: 12rpx; }
.delete-btn { font-size: 24rpx; color: #F44336; }

.empty { text-align: center; padding: 100rpx; color: #999; font-size: 28rpx; line-height: 2; }

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: flex-end;
}
.modal {
  background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 32rpx;
  width: 100%; max-height: 85vh; overflow-y: auto;
}
.modal-title { font-size: 36rpx; font-weight: 700; display: block; margin-bottom: 24rpx; color: #333; }
.form-item { margin-bottom: 24rpx; }
.form-row { display: flex; gap: 20rpx; }
.label { font-size: 28rpx; color: #666; display: block; margin-bottom: 8rpx; }
.input { border: 2rpx solid #eee; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; }

.allergy-grid { display: flex; flex-wrap: wrap; gap: 12rpx; }
.allergy-chip {
  background: #F5F5F5; border-radius: 20rpx; padding: 10rpx 20rpx; font-size: 26rpx; color: #666;
  border: 2rpx solid transparent;
}
.allergy-chip.selected { background: #FFF3E0; color: #E65100; border-color: #FF9800; }

.picker { border: 2rpx solid #eee; border-radius: 12rpx; padding: 16rpx; font-size: 28rpx; color: #999; }

.modal-actions { display: flex; gap: 20rpx; margin-top: 32rpx; }
.cancel-btn { flex: 1; background: #F5F5F5; color: #666; border-radius: 50rpx; padding: 24rpx; font-size: 30rpx; border: none; }
.confirm-btn { flex: 1; background: #FF9800; color: #fff; border-radius: 50rpx; padding: 24rpx; font-size: 30rpx; border: none; }
