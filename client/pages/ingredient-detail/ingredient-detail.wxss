/* pages/ingredient-detail/ingredient-detail.wxss */
page { background: #FFF8F0; font-family: -apple-system, sans-serif; }
.container { padding: 30rpx; }

.ingredient-header { background: #fff; border-radius: 16rpx; padding: 30rpx; margin-bottom: 20rpx; text-align: center; }
.ing-name { font-size: 40rpx; font-weight: 700; color: #333; display: block; margin-bottom: 8rpx; }
.ing-category { font-size: 26rpx; color: #FF9800; background: #FFF3E0; padding: 6rpx 20rpx; border-radius: 50rpx; }

.warning-box {
  background: #FFF3E0; border-radius: 12rpx; padding: 20rpx;
  display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 20rpx;
}
.warn-icon { font-size: 36rpx; }
.warn-title { font-size: 28rpx; font-weight: 600; color: #E65100; display: block; margin-bottom: 4rpx; }
.warn-text { font-size: 26rpx; color: #FF6D00; }

.section { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 16rpx; }

.nutrition-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.n-item { background: #FFF8F0; border-radius: 12rpx; padding: 16rpx; text-align: center; }
.n-val { font-size: 32rpx; font-weight: 700; color: #FF9800; display: block; }
.n-label { font-size: 22rpx; color: #999; }

.notes-text { font-size: 28rpx; color: #666; line-height: 1.8; }

.difficulty-box { background: #FFF9E6; border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #E65100; margin-bottom: 20rpx; }

.recipe-item {
  background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 12rpx;
}
.recipe-name { font-size: 30rpx; font-weight: 600; color: #333; display: block; margin-bottom: 6rpx; }
.recipe-meta { font-size: 24rpx; color: #999; }
